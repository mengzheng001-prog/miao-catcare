# ====================== CatCare 环境变量模板 ======================
# 复制本文件为 .env.local（已在 .gitignore 中排除）后填入真实值。
# 任何场合都不要把 .env.local 提交到 git。
#
# 最小可用配置：DEEPSEEK_API_KEY 必填；扫描件 PDF 推荐再填 DOUBAO_*。

# ===================================================================
# DeepSeek API（必填）—— 把 PDF 抽出的文本结构化为指标 / 医嘱 / 复诊建议
#  申请：https://platform.deepseek.com/  控制台 → API Keys
# ===================================================================
DEEPSEEK_API_KEY=
DEEPSEEK_TIMEOUT_MS=120000

# short：用最简示例（推荐，节约 token）
# full：用完整示例（开发调试用）
DEEPSEEK_SAMPLE_MODE=short

# ===================================================================
# Doubao Vision（可选但强烈推荐）—— 处理扫描件 / 图片型 PDF
#  申请：https://www.volcengine.com/product/doubao  火山方舟控制台
#  MODEL 填"接入点 ID"（形如 ep-2025xxxx）或带版本号的 model id
# ===================================================================
DOUBAO_API_KEY=
DOUBAO_MODEL=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_TIMEOUT_MS=180000
DOUBAO_MAX_PAGES=10

# ===================================================================
# PaddleOCR 服务（可选 · 高阶用户）
# 默认 OCR_MODE=stub：跳过 PaddleOCR，扫描件直接交给 Doubao 视觉
# 若要启用本地 PaddleOCR：参考 README 里的"扫描件增强"章节
# ===================================================================
OCR_MODE=stub
OCR_SERVICE_URL=http://localhost:5005

# ===================================================================
# Node 后端
# ===================================================================
PORT=3001
NODE_ENV=development
# CORS 白名单（逗号分隔）；为空时允许所有 origin。生产请填具体域名。
CORS_ORIGIN=

# ===================================================================
# 前端 Vite（VITE_ 前缀的会暴露到浏览器；不要在这里放任何 Key）
# 同域部署可留空，前端走相对路径 /api。
# ===================================================================
VITE_BACKEND_URL=
