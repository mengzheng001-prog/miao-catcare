{
  "name": "catcare",
  "productName": "CatCare",
  "private": true,
  "version": "0.1.0",
  "description": "宠物医疗档案助手 - PDF 智能解析 + 多宠物管理",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:client": "npm run dev",
    "dev:ocr": "python3 python_ocr_service/app.py",
    "dev:server": "TMPDIR=/tmp tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:all:ocr": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:ocr\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production TMPDIR=/tmp tsx server/index.ts",
    "start:full": "npm run build && npm run start",
    "clean": "rm -rf dist build release",
    "lint": "tsc --noEmit",
    "electron:build-server": "node electron/build-server.mjs",
    "electron:build-all": "npm run build && npm run electron:build-server",
    "electron:dev": "npm run electron:build-all && electron .",
    "electron:pack": "npm run electron:build-all && electron-builder --dir",
    "electron:dist": "npm run electron:build-all && electron-builder",
    "electron:dist:win": "npm run electron:build-all && electron-builder --win",
    "electron:dist:linux": "npm run electron:build-all && electron-builder --linux",
    "electron:dist:mac": "npm run electron:build-all && electron-builder --mac"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-store": "^11.0.2",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
